# moli-server 运行环境配置
# 复制到部署目录后改名使用，例如：
#   cp moli-server.env.example /opt/moli/backend/conf/moli-server.env
#   chmod 600 /opt/moli/backend/conf/moli-server.env

# ---------- 路径 ----------
APP_HOME=/opt/moli/backend
APP_NAME=moli-server

# 留空则自动查找：$APP_HOME/moli-server.jar 或 $APP_HOME/moli-server-*.jar
JAR_FILE=

PID_FILE=/opt/moli/backend/run/moli-server.pid
LOG_DIR=/opt/moli/backend/logs
LOG_FILE=/opt/moli/backend/logs/moli-server.log

# ---------- Java ----------
# 可指定 JAVA_HOME，脚本会优先使用 $JAVA_HOME/bin/java
# JAVA_HOME=/usr/lib/jvm/java-8-openjdk-amd64
JAVA_CMD=java
JAVA_OPTS="-Xms512m -Xmx1024m -XX:+HeapDumpOnOutOfMemoryError -Dfile.encoding=UTF-8 -Duser.timezone=Asia/Shanghai"

# ---------- Spring ----------
SPRING_PROFILES_ACTIVE=pro
# 额外启动参数（可选），例如 --server.port=8888
SPRING_ARGS=

# ---------- 业务密钥（生产务必修改） ----------
SSO_SHARED_SECRET=请替换为随机强密钥

# ---------- 数据库 / Redis（与 application-pro.yml 占位符对应） ----------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=moli
SPRING_DATASOURCE_USERNAME=moli
SPRING_DATASOURCE_PASSWORD=请替换为MySQL密码

SPRING_REDIS_HOST=127.0.0.1
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=
SPRING_REDIS_DATABASE=0

# MinIO（若使用）
# MINIO_ENDPOINT=http://127.0.0.1:9000
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=

# 优雅停止等待秒数
STOP_TIMEOUT=30
